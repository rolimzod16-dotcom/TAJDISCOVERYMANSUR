{
  "version": 2,
  "framework": null,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/storage/objects/uploads/(.*)", "dest": "/public/uploads/$1" },
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/uploads/(.*)", "dest": "/public/uploads/$1" },
    { "src": "/favicon.svg", "dest": "/public/favicon.svg" },
    { "src": "/opengraph.jpg", "dest": "/public/opengraph.jpg" },
    { "src": "/hero-waterfall.gif", "dest": "/public/hero-waterfall.gif" },
    { "src": "/robots.txt", "dest": "/public/robots.txt" },
    { "src": "/sitemap.xml", "dest": "/public/sitemap.xml" },
    { "src": "/i18n-boot.js", "dest": "/public/i18n-boot.js" },
    { "src": "/i18n.js", "dest": "/public/i18n.js" },
    { "src": "/locales/(.*)", "dest": "/public/locales/$1" },
    { "src": "/tour-filter.js", "dest": "/public/tour-filter.js" },
    { "src": "/admin-countries-patch.js", "dest": "/public/admin-countries-patch.js" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}